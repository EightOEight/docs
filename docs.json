{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FrankenPress",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "architecture",
              "quickstart",
              "your-first-site",
              "customizing"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/fp-runtime",
              "components/fp-mu-plugin",
              "components/fp-site-template",
              "components/fp-charts"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/production",
              "operations/configuration",
              "operations/runtime-matrix",
              "operations/upgrade",
              "operations/admin-credential-rotation",
              "operations/logging",
              "operations/email",
              "operations/troubleshooting"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/EightOEight",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "fp-runtime",
        "href": "https://github.com/EightOEight/fp-runtime"
      },
      {
        "label": "fp-charts",
        "href": "https://github.com/EightOEight/fp-charts"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Quickstart",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/EightOEight"
    }
  }
}
